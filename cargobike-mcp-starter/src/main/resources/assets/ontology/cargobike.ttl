
@prefix cb:   <https://example.com/ont/cargobike#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix dbo:  <http://dbpedia.org/ontology/> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix wd:   <http://www.wikidata.org/entity/> .
@prefix gr:   <http://purl.org/goodrelations/v1#> .

###########
# Classes #
###########

cb:CargoBike a rdfs:Class ;
  rdfs:subClassOf dbo:Bicycle ;
  rdfs:subClassOf gr:ProductOrServiceModel ;
  skos:broadMatch wd:Q11442 ;
  owl:hasKey (cb:hasSku) ;
  rdfs:label "Cargo Bike" ;
  rdfs:comment "A bike designed to carry loads." .

cb:EbikeCargoBike a rdfs:Class ;
  rdfs:subClassOf cb:CargoBike ;
  rdfs:label "E-Cargo Bike" ;
  rdfs:comment "An electrically-assisted cargo bike." .

cb:Order a rdfs:Class ;
  owl:hasKey (cb:orderId) ;
  rdfs:label "Order" .

cb:OrderItem a rdfs:Class ;
  rdfs:label "Order Item" .

cb:Customer a rdfs:Class ;
  rdfs:subClassOf gr:BusinessEntity ;
  owl:hasKey (cb:customerId) ;
  rdfs:label "Customer" .

cb:InventoryItem a rdfs:Class ;
  rdfs:label "Inventory Item" .

cb:Price a rdfs:Class ;
  rdfs:label "Price" .

cb:Address a rdfs:Class ;
  rdfs:label "Address" .

cb:ShipmentQuote a rdfs:Class ;
  skos:relatedMatch gr:DeliveryChargeSpecification ;
  rdfs:label "Shipment Quote" .

################
# Data Properties
################

cb:hasSku a rdf:Property ;
  rdfs:label "has SKU" ;
  rdfs:domain [ a rdfs:Class ;
                rdfs:unionOf ( cb:CargoBike cb:InventoryItem cb:OrderItem ) ] ;
  rdfs:range [ a rdfs:Datatype ;
               owl:onDatatype xsd:string ;
               owl:withRestrictions ( [ xsd:pattern "SKU-E?CB-[0-9]+" ] ) ] .

cb:modelName a rdf:Property ;
  rdfs:domain cb:CargoBike ;
  rdfs:range xsd:string .

cb:hasWeightKg a rdf:Property ;
  rdfs:domain cb:CargoBike ;
  rdfs:range xsd:decimal .

cb:hasMaxPayloadKg a rdf:Property ;
  rdfs:domain cb:CargoBike ;
  rdfs:range xsd:decimal .

cb:hasWheelCount a rdf:Property ;
  rdfs:domain cb:CargoBike ;
  rdfs:range xsd:integer .

cb:hasBatteryCapacityWh a rdf:Property ;
  rdfs:domain cb:EbikeCargoBike ;
  rdfs:range xsd:integer .

cb:orderId a rdf:Property ;
  rdfs:domain cb:Order ;
  rdfs:range [ a rdfs:Datatype ;
               owl:onDatatype xsd:string ;
               owl:withRestrictions ( [ xsd:pattern "ORD-[0-9]+" ] ) ] .

cb:hasStatus a rdf:Property ;
  rdfs:domain cb:Order ;
  rdfs:range xsd:string ;
  rdfs:comment "Lifecycle status (e.g., PROCESSING, SHIPPED)." .

cb:amount a rdf:Property ;
  rdfs:domain cb:Price ;
  rdfs:range xsd:decimal .

cb:currency a rdf:Property ;
  rdfs:domain cb:Price ;
  rdfs:range xsd:string ;
  rdfs:comment "ISO 4217 currency code." .

cb:quantity a rdf:Property ;
  rdfs:domain cb:OrderItem ;
  rdfs:range xsd:integer .

cb:warehouseCode a rdf:Property ;
  rdfs:domain cb:InventoryItem ;
  rdfs:range xsd:string .

cb:customerId a rdf:Property ;
  rdfs:domain cb:Customer ;
  rdfs:range [ a rdfs:Datatype ;
               owl:onDatatype xsd:string ;
               owl:withRestrictions ( [ xsd:pattern "BLUBB-[0-9]+" ] ) ] .

cb:fullName a rdf:Property ;
  rdfs:domain cb:Customer ;
  rdfs:range xsd:string .

cb:email a rdf:Property ;
  rdfs:domain cb:Customer ;
  rdfs:range xsd:string .

cb:street a rdf:Property ;
  rdfs:domain cb:Address ;
  rdfs:range xsd:string .

cb:city a rdf:Property ;
  rdfs:domain cb:Address ;
  rdfs:range xsd:string .

cb:postalCode a rdf:Property ;
  rdfs:domain cb:Address ;
  rdfs:range xsd:string .

cb:countryCode a rdf:Property ;
  rdfs:domain cb:Address ;
  rdfs:range xsd:string .

cb:estimatedDays a rdf:Property ;
  rdfs:domain cb:ShipmentQuote ;
  rdfs:range xsd:integer .

##################
# Object Properties
##################

cb:orderedBy a rdf:Property ;
  rdfs:domain cb:Order ;
  rdfs:range cb:Customer .

cb:hasItem a rdf:Property ;
  rdfs:domain cb:Order ;
  rdfs:range cb:OrderItem .

cb:hasUnitPrice a rdf:Property ;
  rdfs:domain cb:OrderItem ;
  rdfs:range cb:Price .

cb:hasTotalPrice a rdf:Property ;
  rdfs:domain [ a rdfs:Class ;
                rdfs:unionOf ( cb:Order cb:ShipmentQuote ) ] ;
  rdfs:range cb:Price .

cb:hasAddress a rdf:Property ;
  rdfs:domain cb:Customer ;
  rdfs:range cb:Address .

cb:shipsTo a rdf:Property ;
  rdfs:domain cb:ShipmentQuote ;
  rdfs:range cb:Address .
