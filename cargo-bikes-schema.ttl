@prefix : <http://example.com/cargobikes#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

##############################################################
# Core Classes
##############################################################

:CargoBike          rdf:type rdfs:Class ;
                    rdfs:label "Cargo Bike" ;
                    rdfs:comment "A bicycle designed to carry loads." .

:BikeComponent      rdf:type rdfs:Class ;
                    rdfs:comment "A component used in cargo bikes, e.g. batteries, belts, brakes." .

:Customer           rdf:type rdfs:Class ;
                    rdfs:comment "A registered customer of the enterprise." .

:Order              rdf:type rdfs:Class ;
                    rdfs:comment "A purchase order created by a customer." .

:OrderItem          rdf:type rdfs:Class ;
                    rdfs:comment "A line item in an order, for a specific product." .

:Warehouse          rdf:type rdfs:Class ;
                    rdfs:comment "A physical storage location operated by the enterprise." .

:StockItem          rdf:type rdfs:Class ;
                    rdfs:comment "Represents the availability of a product in a warehouse." .

:Delivery           rdf:type rdfs:Class ;
                    rdfs:comment "A delivery shipment for an order." .

:MService           rdf:type rdfs:Class ;
                    rdfs:comment "A microservice in the enterprise architecture." .


##############################################################
# Microservices as instances of MService
##############################################################

:ProductService     rdf:type :MService ;
                    rdfs:label "Product Service" ;
                    rdfs:comment "Provides product catalog APIs." .

:OrderService       rdf:type :MService ;
                    rdfs:label "Order Service" ;
                    rdfs:comment "Handles customer orders and order items." .

:CustomerService    rdf:type :MService ;
                    rdfs:label "Customer Service" ;
                    rdfs:comment "Manages customer data." .

:InventoryService   rdf:type :MService ;
                    rdfs:label "Inventory Service" ;
                    rdfs:comment "Tracks stock across warehouses." .

:DeliveryService    rdf:type :MService ;
                    rdfs:label "Delivery Service" ;
                    rdfs:comment "Handles shipment and delivery tracking." .


##############################################################
# Object properties (relations)
##############################################################

# Order relationships
:placedBy           rdf:type rdf:Property ;
                    rdfs:domain :Order ;
                    rdfs:range  :Customer ;
                    rdfs:comment "Links an order to the customer who placed it." .

:hasItem            rdf:type rdf:Property ;
                    rdfs:domain :Order ;
                    rdfs:range  :OrderItem ;
                    rdfs:comment "Links an order to its order items." .

:forProduct         rdf:type rdf:Property ;
                    rdfs:domain :OrderItem ;
                    rdfs:range  :CargoBike ;
                    rdfs:comment "Specifies the product the order item refers to." .


# Product & inventory relationships
:composedOf         rdf:type rdf:Property ;
                    rdfs:domain :CargoBike ;
                    rdfs:range  :BikeComponent ;
                    rdfs:comment "Links a cargo bike to its components." .

:storedIn           rdf:type rdf:Property ;
                    rdfs:domain :StockItem ;
                    rdfs:range  :Warehouse ;
                    rdfs:comment "Where a stock item is located." .

:refersToProduct    rdf:type rdf:Property ;
                    rdfs:domain :StockItem ;
                    rdfs:range  :CargoBike ;
                    rdfs:comment "The product for which this stock item tracks inventory." .


# Delivery relationships
:deliveryFor        rdf:type rdf:Property ;
                    rdfs:domain :Delivery ;
                    rdfs:range  :Order ;
                    rdfs:comment "Links a delivery to the order being delivered." .

:handledBy          rdf:type rdf:Property ;
                    rdfs:domain :Delivery ;
                    rdfs:range  :DeliveryService ;
                    rdfs:comment "Indicates which microservice handles the delivery." .


##############################################################
# API Semantics (shared vocabulary for endpoints)
##############################################################

:exposesResource    rdf:type rdf:Property ;
                    rdfs:domain :MService ;
                    rdfs:range  rdfs:Class ;
                    rdfs:comment "Declares which domain class a microservice exposes in its API." .

# Which service manages which entity
:ProductService     :exposesResource :CargoBike, :BikeComponent .
:OrderService       :exposesResource :Order, :OrderItem .
:CustomerService    :exposesResource :Customer .
:InventoryService   :exposesResource :StockItem, :Warehouse .
:DeliveryService    :exposesResource :Delivery .